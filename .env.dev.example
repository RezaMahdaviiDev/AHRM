# Local development overrides for running AHRM against the Docker Postgres
# defined in docker-compose.yml. Copy to .env to use:
#
#   make db-up
#   cp .env.dev.example .env
#   make run
#
# These values match the docker-compose.yml service. SSL is disabled because the
# local container does not serve TLS (production/Supabase should keep sslmode=require).

HTTP_ADDR=:8080
LOG_LEVEL=info

SUPABASE_ENABLED=true
SUPABASE_DB_HOST=localhost
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=ahrm
SUPABASE_DB_USER=ahrm
SUPABASE_DB_PASSWORD=ahrm
SUPABASE_DB_SSLMODE=disable

# Live market data still requires an Iran-reachable SourceArena token (optional for
# exercising the database layer locally).
SOURCEARENA_API_TOKEN=
SOURCEARENA_HTTP_PROXY=
