# Server
HTTP_ADDR=:8080
LOG_LEVEL=info

# Supabase PostgreSQL (use pooler for IPv4-only servers)
# Example pooler: aws-1-ap-northeast-1.pooler.supabase.com:6543
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=
SUPABASE_DB_SSLMODE=require

# SourceArena
SOURCEARENA_API_TOKEN=
# Required if server is outside Iran (proxy with Iranian egress)
SOURCEARENA_HTTP_PROXY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alert thresholds
ALERT_ARBITRAGE_R_THRESHOLD=0
ALERT_BREADTH_HIGH=0.618
ALERT_BREADTH_LOW=0.4
ALERT_ADVANCE_HIGH=2.0
ALERT_ADVANCE_LOW=0.8
