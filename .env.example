# Server
HTTP_ADDR=:8080
LOG_LEVEL=info

# Supabase PostgreSQL (set SUPABASE_ENABLED=true and fill all fields to enable)
# Example pooler: aws-1-ap-northeast-1.pooler.supabase.com:6543
SUPABASE_ENABLED=false
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=
SUPABASE_DB_NAME=
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_SSLMODE=

# SourceArena (sent as X-Header-Token on v2 candle API)
SOURCEARENA_API_TOKEN=
# Required if server is outside Iran (proxy with Iranian egress)
SOURCEARENA_HTTP_PROXY=

# Bale (comma-separated chat IDs for multiple recipients)
BALE_BOT_TOKEN=
BALE_CHAT_IDS=

# Alert history persistence
# When SUPABASE_ENABLED=false, sent alerts are recorded in data/alerts.db (SQLite).
# This prevents duplicate notifications after server restarts.
# Alerts older than 24 hours are pruned on startup so daily opportunities re-trigger.

# Alert thresholds
ALERT_ARBITRAGE_R_THRESHOLD=0
ALERT_ARBITRAGE_R12_THRESHOLD=10
ALERT_BREADTH_HIGH=0.618
ALERT_BREADTH_LOW=0.4
ALERT_ADVANCE_HIGH=1.4
ALERT_ADVANCE_LOW=0.6
ALERT_COVERED_CALL_ROI_THRESHOLD=30

# Black-Scholes implied volatility (annual rate, e.g. 0.20 = 20%)
RISK_FREE_RATE=0.20

# Snapshot auto-refresh interval for all pages (seconds, default 180 = 3 minutes)
SNAPSHOT_REFRESH_SECONDS=180
